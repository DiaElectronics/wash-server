{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Station Board Availability",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 30,
            "pointSize": 1,
            "lineWidth": 2
          },
          "min": 0,
          "max": 1,
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFFLINE" }, "1": { "text": "ONLINE" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(storage_station_ping_total[15s]) > bool 0",
          "legendFormat": "Station {{station}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Terminal Status (pings/15s)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "rate(storage_station_ping_total[15s]) * 15",
          "legendFormat": "Station {{station}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Board Last Response (seconds ago)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "time() - hal_station_last_success_timestamp",
          "legendFormat": "Station {{station}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Station Command Success (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(hal_station_command_success_total[5m]) * 60",
          "legendFormat": "Station {{station}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Board Last Error (seconds ago)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          },
          "noValue": "No errors"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "time() - hal_station_last_error_timestamp",
          "legendFormat": "Station {{station}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Current Program per Station",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 0, "pointSize": 3, "stacking": { "mode": "none" } },
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "storage_station_current_program",
          "legendFormat": "Station {{station}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Station Balance",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyRUB",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "storage_station_current_balance",
          "legendFormat": "Station {{station}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Ping Rate per Station (per min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(storage_station_ping_total[5m]) * 60",
          "legendFormat": "Station {{station}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Request Rate (storage)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(storage_extapi_http_requests_total[5m])",
          "legendFormat": "{{resource}} {{method}} {{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Motor Speed",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 100 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hal_motor_speed",
          "legendFormat": "Station {{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Money Received (total)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "unit": "currencyRUB",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "storage_money_received_total",
          "legendFormat": "Station {{station}} ({{type}})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "TCP Reconnects (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(hal_rev2_board_tcp_reconnect[5m]) * 60",
          "legendFormat": "{{port}}",
          "refId": "A"
        },
        {
          "expr": "rate(hal_motor_tcp_reconnect[5m]) * 60",
          "legendFormat": "motor {{port}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "DB Call Duration (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(storage_dal_call_duration_seconds_bucket[5m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "DB Errors (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(storage_dal_errors_total[5m]) * 60",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "unit": "percentunit",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"hal\"}[5m])",
          "legendFormat": "HAL CPU",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_seconds_total{job=\"storage\"}[5m])",
          "legendFormat": "Storage CPU",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Process Memory (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"hal\"}",
          "legendFormat": "HAL RSS",
          "refId": "A"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"storage\"}",
          "legendFormat": "Storage RSS",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Go Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "go_goroutines{job=\"hal\"}",
          "legendFormat": "HAL",
          "refId": "A"
        },
        {
          "expr": "go_goroutines{job=\"storage\"}",
          "legendFormat": "Storage",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Go GC Duration (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "go_gc_duration_seconds{job=\"hal\",quantile=\"0.99\"}",
          "legendFormat": "HAL GC p99",
          "refId": "A"
        },
        {
          "expr": "go_gc_duration_seconds{job=\"storage\",quantile=\"0.99\"}",
          "legendFormat": "Storage GC p99",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["wash", "openrbt"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OpenRBT Wash Station",
  "uid": "openrbt-wash",
  "version": 3
}
